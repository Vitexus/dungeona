#!/usr/bin/make -f
# You must remove unused comment lines for the released package.
#export DH_VERBOSE = 1
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,-O1

%:
	dh $@ --with python3

override_dh_install:
	# ensure wrapper scripts are executable in source before dh_install copies them
	chmod 755 debian/usrbin/dungeona debian/usrbin/dungeon_editor || true
	dh_install
	# Ensure installed python scripts use per-user data dir for the DB
	# (replace any direct package-local DB references with XDG/home path)
	for f in debian/tmp/usr/lib/dungeona/*.py; do \
		if [ -f "$f" ]; then \
			sed -i "s|Path(__file__).with_name('dungeon_map.db')|Path.home() / '.local' / 'share' / 'dungeona' / 'dungeon_map.db'|g" "$f" || true; \
		fi; \
	done || true
